{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "paths": {
      "@sportshop/shared-types": ["./src/shared-types"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
